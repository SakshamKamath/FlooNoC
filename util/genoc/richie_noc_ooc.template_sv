  assign mst_${idx}_aw_lock_o            = from_noc_req[${i}][${j}].aw.lock;
  assign mst_${idx}_aw_cache_o           = from_noc_req[${i}][${j}].aw.cache;
  assign mst_${idx}_aw_prot_o            = from_noc_req[${i}][${j}].aw.prot;
  assign mst_${idx}_aw_qos_o             = from_noc_req[${i}][${j}].aw.qos;
  assign mst_${idx}_aw_region_o          = from_noc_req[${i}][${j}].aw.region;
  assign mst_${idx}_aw_atop_o            = from_noc_req[${i}][${j}].aw.atop;
  assign mst_${idx}_aw_user_o            = from_noc_req[${i}][${j}].aw.user;
  assign mst_${idx}_aw_valid_o           = from_noc_req[${i}][${j}].aw_valid;
  assign from_noc_rsp[${i}][${j}].aw_ready    = mst_${idx}_aw_ready_i;
  assign mst_${idx}_w_data_o             = from_noc_req[${i}][${j}].w.data;
  assign mst_${idx}_w_strb_o             = from_noc_req[${i}][${j}].w.strb;
  assign mst_${idx}_w_last_o             = from_noc_req[${i}][${j}].w.last;
  assign mst_${idx}_w_user_o             = from_noc_req[${i}][${j}].w.user;
  assign mst_${idx}_w_valid_o            = from_noc_req[${i}][${j}].w_valid;
  assign from_noc_rsp[${i}][${j}].w_ready     = mst_${idx}_w_ready_i;
  assign from_noc_rsp[${i}][${j}].b.id        = mst_${idx}_b_id_i;
  assign from_noc_rsp[${i}][${j}].b.resp      = mst_${idx}_b_resp_i;
  assign from_noc_rsp[${i}][${j}].b.user      = mst_${idx}_b_user_i;
  assign from_noc_rsp[${i}][${j}].b_valid     = mst_${idx}_b_valid_i;
  assign mst_${idx}_b_ready_o            = from_noc_req[${i}][${j}].b_ready;
  assign mst_${idx}_ar_id_o              = from_noc_req[${i}][${j}].ar.id;
  assign mst_${idx}_ar_addr_o            = from_noc_req[${i}][${j}].ar.addr;
  assign mst_${idx}_ar_len_o             = from_noc_req[${i}][${j}].ar.len;
  assign mst_${idx}_ar_size_o            = from_noc_req[${i}][${j}].ar.size;
  assign mst_${idx}_ar_burst_o           = from_noc_req[${i}][${j}].ar.burst;
  assign mst_${idx}_ar_lock_o            = from_noc_req[${i}][${j}].ar.lock;
  assign mst_${idx}_ar_cache_o           = from_noc_req[${i}][${j}].ar.cache;
  assign mst_${idx}_ar_prot_o            = from_noc_req[${i}][${j}].ar.prot;
  assign mst_${idx}_ar_qos_o             = from_noc_req[${i}][${j}].ar.qos;
  assign mst_${idx}_ar_region_o          = from_noc_req[${i}][${j}].ar.region;
