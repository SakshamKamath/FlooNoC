  output logic              slv_${n_tiles-1}_b_valid_o,
  input  logic              slv_${n_tiles-1}_b_ready_i,
  input  id_t               slv_${n_tiles-1}_ar_id_i,
  input  soc_cfg_pkg::addr_t    slv_${n_tiles-1}_ar_addr_i,
  input  axi_pkg::len_t     slv_${n_tiles-1}_ar_len_i,
  input  axi_pkg::size_t    slv_${n_tiles-1}_ar_size_i,
  input  axi_pkg::burst_t   slv_${n_tiles-1}_ar_burst_i,
  input  logic              slv_${n_tiles-1}_ar_lock_i,
  input  axi_pkg::cache_t   slv_${n_tiles-1}_ar_cache_i,
  input  axi_pkg::prot_t    slv_${n_tiles-1}_ar_prot_i,
  input  axi_pkg::qos_t     slv_${n_tiles-1}_ar_qos_i,
  input  axi_pkg::region_t  slv_${n_tiles-1}_ar_region_i,
  input  soc_cfg_pkg::user_t    slv_${n_tiles-1}_ar_user_i,
