`include "axi/typedef.svh"

module richie_noc_ooc #(
  // SoC
  parameter int unsigned  N_CLUSTERS  = ${n_clusters},
  // AXI
  parameter int unsigned  AXI_DW      = ${dw},
  parameter type data_t               = logic [AXI_DW-1:0],
  parameter type id_t                 = logic [${iw}-1:0],
  parameter type strb_t               = logic [AXI_DW/8-1:0]
) (
  // Clocks and Resets
  input  logic              clk_i,
  input  logic              rst_ni,

% for i in range(n_tiles-1):
  output id_t               mst_${i}_aw_id_o,
  output soc_cfg_pkg::addr_t    mst_${i}_aw_addr_o,
  output axi_pkg::len_t     mst_${i}_aw_len_o,
