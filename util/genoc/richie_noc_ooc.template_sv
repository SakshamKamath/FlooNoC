  output id_t               slv_${n_tiles-1}_r_id_o,
  output data_t             slv_${n_tiles-1}_r_data_o,
  output axi_pkg::resp_t    slv_${n_tiles-1}_r_resp_o,
  output logic              slv_${n_tiles-1}_r_last_o,
  output soc_cfg_pkg::user_t    slv_${n_tiles-1}_r_user_o,
  output logic              slv_${n_tiles-1}_r_valid_o,
  input  logic              slv_${n_tiles-1}_r_ready_i
);

  `AXI_TYPEDEF_AW_CHAN_T(aw_t, soc_cfg_pkg::addr_t, id_t, soc_cfg_pkg::user_t)
  `AXI_TYPEDEF_W_CHAN_T(w_t, data_t, strb_t, soc_cfg_pkg::user_t)
  `AXI_TYPEDEF_B_CHAN_T(b_t, id_t, soc_cfg_pkg::user_t)
  `AXI_TYPEDEF_AR_CHAN_T(ar_t, soc_cfg_pkg::addr_t, id_t, soc_cfg_pkg::user_t)
  `AXI_TYPEDEF_R_CHAN_T(r_t, data_t, id_t, soc_cfg_pkg::user_t)
  `AXI_TYPEDEF_REQ_T(req_t, aw_t, w_t, ar_t)
  `AXI_TYPEDEF_RESP_T(resp_t, b_t, r_t)

  `AXI_LITE_TYPEDEF_AW_CHAN_T(lite_aw_t, soc_cfg_pkg::lite_addr_t)
  `AXI_LITE_TYPEDEF_W_CHAN_T(lite_w_t, soc_cfg_pkg::lite_data_t, soc_cfg_pkg::lite_strb_t)
  `AXI_LITE_TYPEDEF_B_CHAN_T(lite_b_t)
  `AXI_LITE_TYPEDEF_AR_CHAN_T(lite_ar_t, soc_cfg_pkg::lite_addr_t)
  `AXI_LITE_TYPEDEF_R_CHAN_T(lite_r_t, soc_cfg_pkg::lite_data_t)
  `AXI_LITE_TYPEDEF_REQ_T(lite_req_t, lite_aw_t, lite_w_t, lite_ar_t)
  `AXI_LITE_TYPEDEF_RESP_T(lite_resp_t, lite_b_t, lite_r_t)

% if (topology == 0):
  floo_axi_pkg::axi_in_req_t  [${n_tiles_x}-1:0][${n_tiles_y}-1:0] to_noc_req;
  floo_axi_pkg::axi_out_rsp_t [${n_tiles_x}-1:0][${n_tiles_y}-1:0] from_noc_rsp;
  floo_axi_pkg::axi_out_req_t [${n_tiles_x}-1:0][${n_tiles_y}-1:0] from_noc_req;
  floo_axi_pkg::axi_in_rsp_t  [${n_tiles_x}-1:0][${n_tiles_y}-1:0] to_noc_rsp;

  `FLOO_NOC_TYPEDEF_XY_ID_T(xy_id_t, soc_cfg_pkg::NOC_N_TILES_X, soc_cfg_pkg::NOC_N_TILES_Y)

  richie_noc #(
    // NoC topology
    .NumTiles           ( soc_cfg_pkg::NOC_N_TILES              ),
    .NumX               ( soc_cfg_pkg::NOC_N_TILES_X            ),
    .NumY               ( soc_cfg_pkg::NOC_N_TILES_Y            ),
    .NumRoutes          ( floo_pkg::NumDirections               ),
    .NumVirtChannels    ( soc_cfg_pkg::NOC_N_VIRT_CHANNELS      ),
    .NumPhysChannels    ( soc_cfg_pkg::NOC_N_PHYS_CHANNELS      ),
    // Chimney
    .CutAx              ( soc_cfg_pkg::NOC_CUT_AX               ),
    .CutRsp             ( soc_cfg_pkg::NOC_CUT_RSP              ),
    .RoBType            ( soc_cfg_pkg::NOC_ROB_TYPE             ),
    .ReorderBufferSize  ( soc_cfg_pkg::NOC_ROB_SIZE             ),
    .MaxTxns            ( soc_cfg_pkg::NOC_MAX_TXNS             ),
    .RouteAlgo          ( soc_cfg_pkg::NOC_ROUTE_ALGO           ),
    .UseIdTable         ( soc_cfg_pkg::NOC_USE_ID_TABLE         ),
    // .XYAddrOffsetX      ( XYAddrOffsetX                         ),
    // .XYAddrOffsetY      ( XYAddrOffsetY                         ),
    // Router
    .ChannelFifoDepth   ( soc_cfg_pkg::NOC_CH_FIFO_DEPTH        ),
    .OutputFifoDepth    ( soc_cfg_pkg::NOC_OUT_FIFO_DEPTH          ),
    .XYRouteOpt         ( 1'b0                                  ),
    .id_t               ( xy_id_t                               )
  ) i_noc (
    .clk_i              ( clk_i                                 ), 
    .rst_ni             ( rst_ni                                ),
    .test_enable_i      ( 1'b0                                  ),
    .sram_cfg_i         ( '0                                    ),
    .axi_mst_req        ( to_noc_req                            ),
    .axi_mst_rsp        ( to_noc_rsp                            ),
    .axi_slv_req        ( from_noc_req                          ),
    .axi_slv_rsp        ( from_noc_rsp                          )
  );

  % for i in range(n_tiles_x): 
    % for j in range(n_tiles_y): 
  <% idx = i * n_tiles_x + j %>
  // TILE [${i}][${j}]
  assign mst_${idx}_aw_id_o              = from_noc_req[${i}][${j}].aw.id;
  assign mst_${idx}_aw_addr_o            = from_noc_req[${i}][${j}].aw.addr;
  assign mst_${idx}_aw_len_o             = from_noc_req[${i}][${j}].aw.len;
  assign mst_${idx}_aw_size_o            = from_noc_req[${i}][${j}].aw.size;
