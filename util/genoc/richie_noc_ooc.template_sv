  input  axi_pkg::resp_t    mst_${i}_b_resp_i,
  input  soc_cfg_pkg::user_t    mst_${i}_b_user_i,
  input  logic              mst_${i}_b_valid_i,
  output logic              mst_${i}_b_ready_o,
  output id_t               mst_${i}_ar_id_o,
  output soc_cfg_pkg::addr_t    mst_${i}_ar_addr_o,
  output axi_pkg::len_t     mst_${i}_ar_len_o,
  output axi_pkg::size_t    mst_${i}_ar_size_o,
  output axi_pkg::burst_t   mst_${i}_ar_burst_o,
  output logic              mst_${i}_ar_lock_o,
