  input  logic              mst_${n_tiles-1}_aw_ready_i,
  output data_t             mst_${n_tiles-1}_w_data_o,
  output strb_t             mst_${n_tiles-1}_w_strb_o,
  output logic              mst_${n_tiles-1}_w_last_o,
  output soc_cfg_pkg::user_t    mst_${n_tiles-1}_w_user_o,
  output logic              mst_${n_tiles-1}_w_valid_o,
  input  logic              mst_${n_tiles-1}_w_ready_i,
  input  id_t               mst_${n_tiles-1}_b_id_i,
  input  axi_pkg::resp_t    mst_${n_tiles-1}_b_resp_i,
  input  soc_cfg_pkg::user_t    mst_${n_tiles-1}_b_user_i,
  input  logic              mst_${n_tiles-1}_b_valid_i,
  output logic              mst_${n_tiles-1}_b_ready_o,
  output id_t               mst_${n_tiles-1}_ar_id_o,
  output soc_cfg_pkg::addr_t    mst_${n_tiles-1}_ar_addr_o,
  output axi_pkg::len_t     mst_${n_tiles-1}_ar_len_o,
  output axi_pkg::size_t    mst_${n_tiles-1}_ar_size_o,
  output axi_pkg::burst_t   mst_${n_tiles-1}_ar_burst_o,
  output logic              mst_${n_tiles-1}_ar_lock_o,
  output axi_pkg::cache_t   mst_${n_tiles-1}_ar_cache_o,
  output axi_pkg::prot_t    mst_${n_tiles-1}_ar_prot_o,
  output axi_pkg::qos_t     mst_${n_tiles-1}_ar_qos_o,
  output axi_pkg::region_t  mst_${n_tiles-1}_ar_region_o,
  output soc_cfg_pkg::user_t    mst_${n_tiles-1}_ar_user_o,
  output logic              mst_${n_tiles-1}_ar_valid_o,
  input  logic              mst_${n_tiles-1}_ar_ready_i,
  input  id_t               mst_${n_tiles-1}_r_id_i,
  input  data_t             mst_${n_tiles-1}_r_data_i,
  input  axi_pkg::resp_t    mst_${n_tiles-1}_r_resp_i,
  input  logic              mst_${n_tiles-1}_r_last_i,
  input  soc_cfg_pkg::user_t    mst_${n_tiles-1}_r_user_i,
  input  logic              mst_${n_tiles-1}_r_valid_i,
  output logic              mst_${n_tiles-1}_r_ready_o,

  input  id_t               slv_${n_tiles-1}_aw_id_i,
  input  soc_cfg_pkg::addr_t    slv_${n_tiles-1}_aw_addr_i,
  input  axi_pkg::len_t     slv_${n_tiles-1}_aw_len_i,
  input  axi_pkg::size_t    slv_${n_tiles-1}_aw_size_i,
  input  axi_pkg::burst_t   slv_${n_tiles-1}_aw_burst_i,
  input  logic              slv_${n_tiles-1}_aw_lock_i,
