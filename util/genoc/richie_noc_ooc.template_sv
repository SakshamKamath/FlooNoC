  input  axi_pkg::prot_t    slv_${i}_aw_prot_i,
  input  axi_pkg::qos_t     slv_${i}_aw_qos_i,
  input  axi_pkg::region_t  slv_${i}_aw_region_i,
  input  axi_pkg::atop_t    slv_${i}_aw_atop_i,
  input  soc_cfg_pkg::user_t    slv_${i}_aw_user_i,
  input  logic              slv_${i}_aw_valid_i,
  output logic              slv_${i}_aw_ready_o,
  input  data_t             slv_${i}_w_data_i,
  input  strb_t             slv_${i}_w_strb_i,
  input  logic              slv_${i}_w_last_i,
  input  soc_cfg_pkg::user_t    slv_${i}_w_user_i,
  input  logic              slv_${i}_w_valid_i,
  output logic              slv_${i}_w_ready_o,
  output id_t               slv_${i}_b_id_o,
  output axi_pkg::resp_t    slv_${i}_b_resp_o,
  output soc_cfg_pkg::user_t    slv_${i}_b_user_o,
  output logic              slv_${i}_b_valid_o,
  input  logic              slv_${i}_b_ready_i,
  input  id_t               slv_${i}_ar_id_i,
  input  soc_cfg_pkg::addr_t    slv_${i}_ar_addr_i,
  input  axi_pkg::len_t     slv_${i}_ar_len_i,
  input  axi_pkg::size_t    slv_${i}_ar_size_i,
  input  axi_pkg::burst_t   slv_${i}_ar_burst_i,
  input  logic              slv_${i}_ar_lock_i,
  input  axi_pkg::cache_t   slv_${i}_ar_cache_i,
  input  axi_pkg::prot_t    slv_${i}_ar_prot_i,
  input  axi_pkg::qos_t     slv_${i}_ar_qos_i,
  input  axi_pkg::region_t  slv_${i}_ar_region_i,
  input  soc_cfg_pkg::user_t    slv_${i}_ar_user_i,
  input  logic              slv_${i}_ar_valid_i,
  output logic              slv_${i}_ar_ready_o,
  output id_t               slv_${i}_r_id_o,
  output data_t             slv_${i}_r_data_o,
  output axi_pkg::resp_t    slv_${i}_r_resp_o,
  output logic              slv_${i}_r_last_o,
  output soc_cfg_pkg::user_t    slv_${i}_r_user_o,
  output logic              slv_${i}_r_valid_o,
  input  logic              slv_${i}_r_ready_i,
% endfor

  output id_t               mst_${n_tiles-1}_aw_id_o,
  output soc_cfg_pkg::addr_t    mst_${n_tiles-1}_aw_addr_o,
  output axi_pkg::len_t     mst_${n_tiles-1}_aw_len_o,
  output axi_pkg::size_t    mst_${n_tiles-1}_aw_size_o,
  output axi_pkg::burst_t   mst_${n_tiles-1}_aw_burst_o,
  output logic              mst_${n_tiles-1}_aw_lock_o,
  output axi_pkg::cache_t   mst_${n_tiles-1}_aw_cache_o,
