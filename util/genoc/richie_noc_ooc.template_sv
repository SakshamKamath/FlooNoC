  output axi_pkg::prot_t    mst_${i}_ar_prot_o,
  output axi_pkg::qos_t     mst_${i}_ar_qos_o,
  output axi_pkg::region_t  mst_${i}_ar_region_o,
  output soc_cfg_pkg::user_t    mst_${i}_ar_user_o,
  output logic              mst_${i}_ar_valid_o,
  input  logic              mst_${i}_ar_ready_i,
  input  id_t               mst_${i}_r_id_i,
  input  data_t             mst_${i}_r_data_i,
  input  axi_pkg::resp_t    mst_${i}_r_resp_i,
  input  logic              mst_${i}_r_last_i,
  input  soc_cfg_pkg::user_t    mst_${i}_r_user_i,
  input  logic              mst_${i}_r_valid_i,
  output logic              mst_${i}_r_ready_o,

  input  id_t               slv_${i}_aw_id_i,
  input  soc_cfg_pkg::addr_t    slv_${i}_aw_addr_i,
  input  axi_pkg::len_t     slv_${i}_aw_len_i,
  input  axi_pkg::size_t    slv_${i}_aw_size_i,
  input  axi_pkg::burst_t   slv_${i}_aw_burst_i,
  input  logic              slv_${i}_aw_lock_i,
