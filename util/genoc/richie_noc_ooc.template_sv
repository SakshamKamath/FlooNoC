    .AXI_USER_WIDTH (soc_cfg_pkg::AXI_UW)
  ) slv [${n_tiles}-1:0]();

  localparam axi_pkg::xbar_cfg_t XbarCfg = '{
    NoSlvPorts:         ${n_tiles},
    NoMstPorts:         ${n_tiles},
    MaxMstTrans:        4,
    MaxSlvTrans:        4,
    FallThrough:        1'b0,
    LatencyMode:        axi_pkg::CUT_ALL_PORTS,
    PipelineStages:     1,
    AxiIdWidthSlvPorts: soc_cfg_pkg::AXI_IW_SB_INP,
    AxiIdUsedSlvPorts:  soc_cfg_pkg::AXI_IW_SB_INP,
    UniqueIds:          0,
    AxiAddrWidth:       soc_cfg_pkg::AXI_AW,
    AxiDataWidth:       soc_cfg_pkg::AXI_DW,
    NoAddrRules:        ${n_tiles}
  };
  
  typedef axi_pkg::xbar_rule_64_t rule_t;
  rule_t [${n_tiles}-1:0] addr_map;

  for (genvar i = 0; i < ${n_tiles}; i++) begin : gen_map_tiles
    assign addr_map[i+1] = '{
      idx:        i,
      start_addr: 64'h0000_0000_1000_0000 + i * 32'h0010_0000,
      end_addr:   64'h0000_0000_1000_0000 + i * 32'h0010_0000 + 32'h002F_FFFF
    };
  end

  axi_xbar_intf #(
    .AXI_USER_WIDTH (soc_cfg_pkg::AXI_UW),
    .Cfg            (XbarCfg),
    .rule_t         (rule_t)
  ) i_axi_xbar (
    .clk_i,
    .rst_ni,
    .test_i                 (1'b0),
    .slv_ports              (slv),
    .mst_ports              (mst),
    .addr_map_i             (addr_map),
    .en_default_mst_port_i  ('0),
    .default_mst_port_i     ('0)
  );

